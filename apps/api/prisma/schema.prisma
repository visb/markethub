generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RoleName {
  customer
  picker
  driver
  merchant
  admin
}

model User {
  id           String       @id @default(cuid())
  email        String       @unique
  passwordHash String
  name         String
  active       Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  roles        UserRole[]
  sessions     Session[]
  staffOf      StoreStaff[]
  addresses    Address[]
  cart         Cart?
  orders       Order[]
  pickTasks    PickTask[]   @relation("PickerTasks")
  driverProfile  DriverProfile?
  deliveryRoutes DeliveryRoute[]

  @@map("users")
}

model Role {
  id    String     @id @default(cuid())
  name  RoleName   @unique
  users UserRole[]

  @@map("roles")
}

model UserRole {
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)
  roleId String

  @@id([userId, roleId])
  @@map("user_roles")
}

// Refresh-token session. Suporta rotação e revogação (detecção de reuse).
model Session {
  id               String    @id @default(cuid())
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId           String
  refreshTokenHash String
  userAgent        String?
  expiresAt        DateTime
  revokedAt        DateTime?
  replacedBySessionId String?
  createdAt        DateTime  @default(now())

  @@index([userId])
  @@map("sessions")
}

// Papel do funcionário dentro de uma loja.
enum StaffRole {
  manager // usuário do merchant que gerencia a loja
  picker // separador (faz o picking)
}

// Vínculo de um usuário (funcionário) a uma loja específica, com papel operacional.
model StoreStaff {
  id        String    @id @default(cuid())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  store     Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  storeId   String
  staffRole StaffRole
  active    Boolean   @default(true)
  createdAt DateTime  @default(now())

  @@unique([userId, storeId, staffRole])
  @@index([storeId])
  @@map("store_staff")
}

// ─────────────────────────────────────────────────────────────
// Catálogo (S1.1)
// Produto CANÔNICO (global) é separado da OFERTA (por loja). Isso viabiliza
// dedup e enriquecimento entre lojas/merchants.
// ─────────────────────────────────────────────────────────────

enum EnrichmentStatus {
  pending
  enriched
  needs_review
}

// Como o produto é vendido — dirige o input de quantidade no carrinho.
// unit = embalado (conta unidades); weight = vendido por peso (carne, frutas, frios).
enum SaleType {
  unit
  weight
}

// Rede/varejista (ex.: Supermercado Europa).
model Merchant {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  active    Boolean  @default(true)
  // Integração ERP (S1.2): tipo de conector e config (ex.: { "dir": "..." } pro CSV).
  connectorType   String?
  connectorConfig Json?
  // Tarifas (S2.4) — em centavos / basis points.
  deliveryFeeCents Int @default(700)
  prepFeeCents     Int @default(0)
  platformFeeBps   Int @default(1000) // 1000 = 10%
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  stores    Store[]
  orderGroups OrderGroup[]
  coupons   Coupon[]

  @@map("merchants")
}

// Loja física de um merchant. Origem dos dados do ERP.
model Store {
  id         String   @id @default(cuid())
  merchant   Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  merchantId String
  name       String
  externalId String? // id da loja no ERP do merchant
  // endereço
  street     String?
  number     String?
  district   String?
  city       String?
  state      String?
  zipCode    String?
  latitude   Float?
  longitude  Float?
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  offers     Offer[]
  stocks     Stock[]
  staff      StoreStaff[]
  orderGroups OrderGroup[]
  pickupStops RouteStop[] @relation("StopPickupStore")

  @@unique([merchantId, externalId])
  @@index([merchantId])
  @@map("stores")
}

// Categoria CRUA (origem ERP/Cosmos, criada automaticamente). Mapeia para uma categoria
// CURADA (MarketplaceCategory) que é o que aparece no marketplace.
model Category {
  id       String     @id @default(cuid())
  name     String
  slug     String     @unique
  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  parentId String?
  children Category[] @relation("CategoryTree")
  products Product[]
  mappings CategoryMapping[]
  // Curadoria: categoria do marketplace que agrupa esta categoria crua.
  marketplaceCategory   MarketplaceCategory? @relation(fields: [marketplaceCategoryId], references: [id])
  marketplaceCategoryId String?

  @@index([parentId])
  @@index([marketplaceCategoryId])
  @@map("categories")
}

// Categoria CURADA, gerida pelo admin — é o que aparece no marketplace (app cliente).
model MarketplaceCategory {
  id           String                @id @default(cuid())
  name         String
  slug         String                @unique
  displayOrder Int                   @default(0)
  visible      Boolean               @default(true)
  parent       MarketplaceCategory?  @relation("MktCatTree", fields: [parentId], references: [id])
  parentId     String?
  children     MarketplaceCategory[] @relation("MktCatTree")
  rawCategories Category[]
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt

  @@index([parentId])
  @@index([visible, displayOrder])
  @@map("marketplace_categories")
}

// Produto canônico (global, cross-loja). Enriquecido pelo pipeline (S1.5).
model Product {
  id               String           @id @default(cuid())
  gtin             String?          @unique // EAN/GTIN normalizado quando houver
  name             String
  brand            String?
  packageSize      String? // rótulo descritivo da embalagem: "2L", "380g", "1kg"
  saleType         SaleType @default(unit) // un|weight — dirige input de quantidade no carrinho
  imageUrl         String?
  description      String?
  category         Category?        @relation(fields: [categoryId], references: [id])
  categoryId       String?
  enrichmentStatus EnrichmentStatus @default(pending)
  completenessScore Int             @default(0) // 0-100
  // Origem do produto: erp | cosmos | merchant (cadastrado pelo manager — S3.10).
  source           String           @default("erp")
  createdById      String? // manager que cadastrou (produto local — S3.10)
  // Campos editados manualmente (S1.7) que o pipeline NÃO sobrescreve.
  lockedFields     String[]         @default([])
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  offers           Offer[]
  stocks           Stock[]
  enrichment       ProductEnrichment?

  @@index([name])
  @@index([brand])
  @@index([categoryId])
  @@index([enrichmentStatus])
  @@map("products")
}

// Oferta de um produto numa loja: preço + disponibilidade. Reconcilia ERP via externalId.
model Offer {
  id           String   @id @default(cuid())
  store        Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  storeId      String
  product      Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId    String
  externalId   String? // id do produto no ERP daquela loja
  priceCents   Int
  promoPriceCents Int?
  available    Boolean  @default(true)
  // Campos editados manualmente pelo manager (S3.9) que o sync ERP NÃO sobrescreve.
  lockedFields String[] @default([])
  updatedById  String? // auditoria: último editor manual (User)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  cartItems    CartItem[]

  @@unique([storeId, productId])
  @@unique([storeId, externalId])
  @@index([productId])
  @@map("offers")
}

// Estoque por loja/produto (quantidade opcional; alguns ERPs só dão flag).
model Stock {
  id        String   @id @default(cuid())
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  storeId   String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId String
  quantity  Int?
  available Boolean  @default(true)
  // Campos editados manualmente pelo manager (S3.9) que o sync ERP NÃO sobrescreve.
  lockedFields String[] @default([])
  updatedById  String? // auditoria: último editor manual (User)
  updatedAt DateTime @updatedAt

  @@unique([storeId, productId])
  @@index([productId])
  @@map("stocks")
}

// ─────────────────────────────────────────────────────────────
// Integração ERP — auditoria de sync (S1.2)
// ─────────────────────────────────────────────────────────────

enum SyncType {
  full
  prices
  stock
}

enum SyncStatus {
  running
  success
  failed
}

model SyncRun {
  id             String     @id @default(cuid())
  storeId        String
  type           SyncType
  status         SyncStatus @default(running)
  startedAt      DateTime   @default(now())
  finishedAt     DateTime?
  itemsProcessed Int        @default(0)
  itemsUpdated   Int        @default(0)
  itemsFailed    Int        @default(0)
  error          String?

  @@index([storeId, startedAt])
  @@map("sync_runs")
}

// ─────────────────────────────────────────────────────────────
// Enriquecimento (S1.5) — Cosmos Bluesoft + mapeamento de categoria
// ─────────────────────────────────────────────────────────────

// Cache de respostas do Cosmos por GTIN (rate limit + evitar recomputo).
model CosmosCache {
  gtin      String   @id
  found     Boolean
  payload   Json?
  fetchedAt DateTime @default(now())

  @@map("cosmos_cache")
}

// Mapeamento categoria de origem (ex.: Cosmos GPC/descrição) → Category da plataforma.
// Persistido e reusado; IA/heurística só roda para sourceKey novo.
model CategoryMapping {
  id         String    @id @default(cuid())
  source     String // "cosmos"
  sourceKey  String // texto da categoria de origem
  category   Category? @relation(fields: [categoryId], references: [id])
  categoryId String?
  confidence Float     @default(0)
  mapper     String // "heuristic" | "ai" | "manual"
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@unique([source, sourceKey])
  @@map("category_mappings")
}

// Dados crus do enriquecimento + proveniência por campo (auditoria).
model ProductEnrichment {
  productId  String   @id
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  source     String // "cosmos" | "mock"
  raw        Json?
  provenance Json? // { name: "cosmos", category: "heuristic", ... }
  fetchedAt  DateTime @default(now())

  @@map("product_enrichments")
}

// ─────────────────────────────────────────────────────────────
// Marketplace — pedido, carrinho, endereço, cupom, pagamento (Fase 2)
// ─────────────────────────────────────────────────────────────

enum DeliveryMethod {
  gate // receber na portaria/portão
  door // entregar na porta (+taxa)
}

enum OrderStatus {
  created
  paid
  preparing
  picking
  ready_for_pickup // separado e empacotado, aguardando coleta do entregador (S3.1)
  on_the_way
  delivered
  canceled
}

enum PaymentStatus {
  pending
  paid
  expired
  failed
  refunded
}

enum CouponType {
  fixed // valor fixo em centavos
  percent // percentual (value = %)
  free_shipping
}

model Address {
  id         String   @id @default(cuid())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String
  label      String // Casa, Trabalho...
  street     String
  number     String
  district   String?
  city       String
  state      String
  zipCode    String
  complement String?
  latitude   Float?
  longitude  Float?
  isDefault  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  orders     Order[]

  @@index([userId])
  @@map("addresses")
}

model Cart {
  id         String     @id @default(cuid())
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String     @unique
  couponCode String?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  items      CartItem[]

  @@map("carts")
}

model CartItem {
  id          String   @id @default(cuid())
  cart        Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  cartId      String
  offer       Offer    @relation(fields: [offerId], references: [id], onDelete: Cascade)
  offerId     String
  quantity    Int      @default(1) // saleType=unit: nº de unidades
  weightGrams Int? // saleType=weight: gramas
  note        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([cartId, offerId])
  @@index([cartId])
  @@map("cart_items")
}

model Coupon {
  id          String     @id @default(cuid())
  code        String     @unique
  type        CouponType
  value       Int        @default(0) // fixed: centavos; percent: %
  merchant    Merchant?  @relation(fields: [merchantId], references: [id])
  merchantId  String? // null = global
  minOrderCents Int?
  validFrom   DateTime?
  validTo     DateTime?
  maxUses     Int?
  usedCount   Int        @default(0)
  active      Boolean    @default(true)
  createdAt   DateTime   @default(now())

  @@map("coupons")
}

model Order {
  id        String      @id @default(cuid())
  user      User        @relation(fields: [userId], references: [id])
  userId    String
  status    OrderStatus @default(created)
  // entrega
  address        Address?      @relation(fields: [addressId], references: [id])
  addressId      String?
  deliveryMethod DeliveryMethod @default(gate)
  scheduledFrom  DateTime?
  scheduledTo    DateTime?
  // snapshot do endereço (caso o Address mude/seja apagado)
  addressSnapshot Json?
  // totais (centavos)
  itemsCents       Int @default(0)
  deliveryCents    Int @default(0)
  prepCents        Int @default(0)
  platformFeeCents Int @default(0)
  discountCents    Int @default(0)
  totalCents       Int @default(0)
  couponCode       String?
  // código de entrega (entregador→cliente): exibido ao cliente; o entregador digita p/ confirmar (SF.1)
  deliveryCode     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  groups    OrderGroup[]
  payment   Payment?
  refund    Refund?
  dropoffStops RouteStop[] @relation("StopDropoffOrder")

  @@index([userId, createdAt])
  @@index([status])
  @@map("orders")
}

model OrderGroup {
  id         String   @id @default(cuid())
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId    String
  merchant   Merchant @relation(fields: [merchantId], references: [id])
  merchantId String
  store      Store    @relation(fields: [storeId], references: [id])
  storeId    String
  status     OrderStatus @default(created)
  subtotalCents    Int @default(0)
  deliveryCents    Int @default(0)
  prepCents        Int @default(0)
  platformFeeCents Int @default(0)
  // código de coleta (loja→entregador): exibido ao entregador; o picker/merchant digita p/ liberar (SF.1)
  pickupCode      String?
  // push ao ERP (S2.7)
  externalOrderId String?
  erpPushedAt     DateTime?
  items      OrderItem[]
  pickTask   PickTask?
  refundComponents RefundComponent[]
  // parada de coleta da rota de entrega (S4.1): grupos de uma loja na mesma parada
  pickupStop   RouteStop? @relation("StopPickupGroups", fields: [pickupStopId], references: [id])
  pickupStopId String?

  @@index([orderId])
  @@index([storeId])
  @@index([pickupStopId])
  @@map("order_groups")
}

model OrderItem {
  id            String   @id @default(cuid())
  group         OrderGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  groupId       String
  // snapshot (catálogo pode mudar depois)
  productId     String?
  offerId       String?
  nameSnapshot  String
  gtinSnapshot  String?
  saleType      SaleType @default(unit)
  unitPriceCents Int // unit: preço/un; weight: preço/kg
  quantity      Int      @default(1)
  weightGrams   Int?
  lineTotalCents Int
  pickItem      PickItem?

  @@index([groupId])
  @@map("order_items")
}

model Payment {
  id              String        @id @default(cuid())
  order           Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId         String        @unique
  provider        String // "pagarme" | "mock"
  providerChargeId String?
  method          String        @default("pix")
  status          PaymentStatus @default(pending)
  amountCents     Int
  pixQrCode       String?
  pixQrCodeUrl    String?
  expiresAt       DateTime?
  paidAt          DateTime?
  raw             Json?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([providerChargeId])
  @@map("payments")
}

enum RefundStatus {
  pending // criado, ainda não processado no gateway
  processed // estorno confirmado pelo provider
  failed // gateway recusou o estorno
}

enum RefundReason {
  weight_shortfall // separou menos gramas que o pedido (item de peso)
  refused // item recusado/sem estoque (valor integral)
}

// Reembolso único por Order (SF.3): consolida faltas de peso e itens recusados de
// todos os grupos. amountCents = max(0, pago − total ajustado). Breakdown por grupo
// em RefundComponent (contábil/repasse ao merchant).
model Refund {
  id               String       @id @default(cuid())
  order            Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId          String       @unique
  amountCents      Int
  status           RefundStatus @default(pending)
  provider         String // "pagarme" | "mock"
  providerRefundId String?
  reason           String // resumo legível (ex.: "weight_shortfall+refused")
  createdAt        DateTime     @default(now())
  processedAt      DateTime?
  components       RefundComponent[]

  @@map("refunds")
}

model RefundComponent {
  id           String       @id @default(cuid())
  refund       Refund       @relation(fields: [refundId], references: [id], onDelete: Cascade)
  refundId     String
  orderGroup   OrderGroup   @relation(fields: [orderGroupId], references: [id], onDelete: Cascade)
  orderGroupId String
  amountCents  Int
  reason       RefundReason

  @@index([refundId])
  @@index([orderGroupId])
  @@map("refund_components")
}

// ─────────────────────────────────────────────────────────────
// Picking / Separação (Fase 3 — S3.1)
// Uma PickTask por OrderGroup (sub-pedido de uma loja). O separador (picker)
// resolve item a item, ensacola e libera p/ coleta do entregador via pickupCode.
// ─────────────────────────────────────────────────────────────

enum PickTaskStatus {
  queued // gerada, aguardando separador assumir
  assigned // separador assumiu
  picking // separação em andamento
  packed // itens ensacolados/prontos
  ready_for_pickup // pronta p/ coleta do entregador
}

enum PickItemStatus {
  pending // ainda não resolvido ("a selecionar")
  picked // separado ("selecionado")
  refused // sem estoque/avariado, removido ("reembolsado")
  substituted // substituído por outro produto
}

enum SubstitutionStatus {
  pending // aguardando aprovação do cliente
  approved
  rejected
}

model PickTask {
  id           String         @id @default(cuid())
  orderGroup   OrderGroup     @relation(fields: [orderGroupId], references: [id], onDelete: Cascade)
  orderGroupId String         @unique
  storeId      String // denormalizado p/ fila/índice por loja (== orderGroup.storeId)
  picker       User?          @relation("PickerTasks", fields: [pickerId], references: [id])
  pickerId     String?
  status       PickTaskStatus @default(queued)
  assignedAt   DateTime?
  startedAt    DateTime?
  packedAt     DateTime?
  readyAt      DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  items        PickItem[]

  @@index([storeId, status])
  @@index([pickerId])
  @@map("pick_tasks")
}

model PickItem {
  id                String         @id @default(cuid())
  pickTask          PickTask       @relation(fields: [pickTaskId], references: [id], onDelete: Cascade)
  pickTaskId        String
  orderItem         OrderItem      @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  orderItemId       String         @unique
  status            PickItemStatus @default(pending)
  quantityPicked    Int? // saleType=unit: unidades efetivamente separadas
  weightGramsPicked Int? // saleType=weight: gramas efetivamente separadas
  refusalReason     String? // motivo quando refused
  pickedById        String? // auditoria: quem resolveu
  pickedAt          DateTime?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  substitution      Substitution?

  @@index([pickTaskId])
  @@map("pick_items")
}

// Proposta de substituto para um item sem estoque. Snapshot de preço (não referência
// viva à Offer) p/ congelar o valor mostrado/aprovado pelo cliente.
model Substitution {
  id                  String             @id @default(cuid())
  pickItem            PickItem           @relation(fields: [pickItemId], references: [id], onDelete: Cascade)
  pickItemId          String             @unique
  substituteOfferId   String? // Offer proposta (referência fraca; sem FK p/ preservar histórico)
  substituteProductId String?
  nameSnapshot        String // nome do substituto no momento da proposta
  unitPriceCents      Int // preço do substituto no momento
  priceDiffCents      Int // substituto - original (pode ser negativo)
  approvalStatus      SubstitutionStatus @default(pending)
  resolvedAt          DateTime?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  @@map("substitutions")
}

// ─────────────────────────────────────────────────────────────
// Delivery / Entrega (Fase 4 — S4.1)
// Perfil do entregador, rotas multi-stop (coleta + entrega) e suas paradas.
// Coleta liberada por pickupCode (OrderGroup); entrega confirmada por
// deliveryCode (Order) — sem caixa/QR (SF.1).
// ─────────────────────────────────────────────────────────────

enum DriverStatus {
  offline // indisponível
  available // disponível p/ ofertas
  on_route // em rota ativa
}

enum DeliveryRouteStatus {
  offered // ofertada a um entregador, aguardando aceite
  accepted // aceita, ainda não iniciada
  in_progress // em execução (coletando/entregando)
  completed // concluída
  canceled // cancelada
  expired // oferta expirou sem aceite
}

enum RouteStopType {
  pickup // coleta na loja
  dropoff // entrega ao cliente
}

enum RouteStopStatus {
  pending // ainda não chegou
  arrived // entregador chegou
  done // parada concluída
}

// Perfil 1:1 do entregador (User com role driver). Disponibilidade + última posição.
model DriverProfile {
  id          String       @id @default(cuid())
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String       @unique
  vehicleType String       @default("moto")
  status      DriverStatus @default(offline)
  currentLat  Float?
  currentLng  Float?
  lastSeenAt  DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([status])
  @@map("driver_profiles")
}

// Rota multi-stop ofertada/atribuída a um entregador. Ganho/distância snapshotados
// na criação (não recalcular após o aceite).
model DeliveryRoute {
  id                    String              @id @default(cuid())
  driver                User?               @relation(fields: [driverId], references: [id])
  driverId              String?
  status                DeliveryRouteStatus @default(offered)
  estimatedEarningsCents Int                @default(0)
  distanceMeters        Int                 @default(0)
  // entregadores que recusaram esta rota (não reofertar) — lista de userIds
  rejectedBy            String[]            @default([])
  offeredAt             DateTime?
  acceptedAt            DateTime?
  completedAt           DateTime?
  offerExpiresAt        DateTime?
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  stops                 RouteStop[]

  @@index([driverId, status])
  @@index([status])
  @@map("delivery_routes")
}

// Parada da rota. pickup → Store (1+ OrderGroup prontas); dropoff → Order.
model RouteStop {
  id        String          @id @default(cuid())
  route     DeliveryRoute   @relation(fields: [routeId], references: [id], onDelete: Cascade)
  routeId   String
  sequence  Int
  type      RouteStopType
  status    RouteStopStatus @default(pending)
  // pickup
  store     Store?          @relation("StopPickupStore", fields: [storeId], references: [id])
  storeId   String?
  groups    OrderGroup[]    @relation("StopPickupGroups")
  // dropoff
  order     Order?          @relation("StopDropoffOrder", fields: [orderId], references: [id])
  orderId   String?
  arrivedAt DateTime?
  doneAt    DateTime?
  createdAt DateTime        @default(now())

  @@index([routeId])
  @@map("route_stops")
}

