{
  "name": "@markethub/driver",
  "version": "0.0.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "dev": "expo start --port 8083",
    "android": "expo start --android --port 8083",
    "ios": "expo start --ios --port 8083",
    "web": "expo start --web --port 8083",
    "build": "echo \"@markethub/driver: use expo build/export\"",
    "typecheck": "tsc --noEmit",
    "lint": "echo \"skip\""
  },
  "dependencies": {
    "@markethub/api-client": "workspace:*",
    "@markethub/ui": "workspace:*",
    "expo": "~52.0.0",
    "expo-constants": "~17.0.0",
    "expo-linking": "~7.0.0",
    "expo-router": "~4.0.0",
    "expo-secure-store": "~14.0.0",
    "expo-status-bar": "~2.0.0",
    "react": "18.3.1",
    "react-native": "0.76.5",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.4.0"
  },
  "devDependencies": {
    "@types/react": "~18.3.12",
    "typescript": "^5.7.3"
  }
}
