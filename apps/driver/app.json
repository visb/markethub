{
  "expo": {
    "name": "MarketHub Entregador",
    "slug": "markethub-driver",
    "scheme": "markethubdriver",
    "version": "0.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#00A859"
    },
    "ios": { "supportsTablet": true, "bundleIdentifier": "com.markethub.driver" },
    "android": { "package": "com.markethub.driver" },
    "web": { "bundler": "metro", "output": "single" },
    "plugins": ["expo-router", "expo-secure-store"]
  }
}
