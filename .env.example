# ─── API ───────────────────────────────────────────────
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1
CORS_ORIGINS=*
LOG_LEVEL=info

# ─── Database (Postgres) ───────────────────────────────
DATABASE_URL=postgresql://markethub:markethub@localhost:5433/markethub?schema=public

# ─── Auth (JWT) ────────────────────────────────────────
JWT_ACCESS_SECRET=dev_access_secret_change_me_please
JWT_REFRESH_SECRET=dev_refresh_secret_change_me_please
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# ─── Redis (filas BullMQ — Fase 1+) ────────────────────
REDIS_URL=redis://localhost:6380

# ─── Storage (MinIO / S3 — Fase 1+) ────────────────────
S3_ENDPOINT=http://localhost:9002
S3_REGION=us-east-1
S3_ACCESS_KEY=markethub
S3_SECRET_KEY=markethub123
S3_BUCKET=markethub

# ─── Enriquecimento (Cosmos Bluesoft — Fase 1) ─────────
# Vazio => MockEnrichmentProvider (dev/test sem token)
COSMOS_TOKEN=
COSMOS_BASE_URL=https://api.cosmos.bluesoft.com.br

# Sync ERP agendado (Fase 1)
SYNC_SCHEDULE_ENABLED=false
SYNC_CRON=*/30 * * * *

# ─── Pagamento PIX (gateway — Fase 2) ──────────────────
PIX_PROVIDER=
PIX_API_KEY=

# ─── Maps / rotas (Google — Fase 4) ────────────────────
GOOGLE_MAPS_API_KEY=
