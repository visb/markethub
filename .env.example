# ─── API ───────────────────────────────────────────────
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1
CORS_ORIGINS=*
LOG_LEVEL=info

# ─── Database (Postgres) ───────────────────────────────
DATABASE_URL=postgresql://markethub:markethub@localhost:5433/markethub?schema=public

# ─── Auth (JWT) ────────────────────────────────────────
JWT_ACCESS_SECRET=dev_access_secret_change_me_please
JWT_REFRESH_SECRET=dev_refresh_secret_change_me_please
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# ─── Redis (filas BullMQ — Fase 1+) ────────────────────
REDIS_URL=redis://localhost:6380

# ─── Storage (MinIO / S3 — Fase 1+) ────────────────────
S3_ENDPOINT=http://localhost:9002
S3_REGION=us-east-1
S3_ACCESS_KEY=markethub
S3_SECRET_KEY=markethub123
S3_BUCKET=markethub

# ─── Enriquecimento (Cosmos Bluesoft — Fase 1) ─────────
# Vazio => MockEnrichmentProvider (dev/test sem token)
COSMOS_TOKEN=
COSMOS_BASE_URL=https://api.cosmos.bluesoft.com.br

# Sync ERP agendado (Fase 1)
SYNC_SCHEDULE_ENABLED=false
SYNC_CRON=*/30 * * * *

# ─── Pagamento PIX (Pagar.me — Fase 2) ─────────────────
# mock = sem gateway (dev/test). pagarme = gateway real.
PAYMENT_PROVIDER=mock
PAGARME_SECRET_KEY=
PAGARME_BASE_URL=https://api.pagar.me/core/v5
PAGARME_WEBHOOK_SECRET=
PIX_EXPIRES_SECONDS=1800

# ─── Notificações push (S5.6 / story 50) ───────────────
# mock = só log (dev/test); expo = Expo Push Service (exp.host, sem chave p/ uso
# básico — funciona em Expo Go / dev build); fcm = Firebase (exige FCM_SERVER_KEY).
PUSH_PROVIDER=mock
FCM_SERVER_KEY=

# ─── Geocodificação de endereço (S6.2 / story 75) ──────
# mock = determinístico em Curitiba (dev/test); nominatim = OpenStreetMap (sem
# chave, precisão fraca p/ rua+número no BR); google = Google Geocoding (precisão
# rua+número, exige GOOGLE_MAPS_API_KEY abaixo).
GEOCODING_PROVIDER=mock
NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org

# ─── Maps / rotas (Google — Fase 4) ────────────────────
# GOOGLE_MAPS_API_KEY habilita GEOCODING_PROVIDER=google e ROUTING_PROVIDER=google.
GOOGLE_MAPS_API_KEY=
