generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RoleName {
  customer
  picker
  driver
  merchant
  admin
}

model User {
  id               String        @id @default(cuid())
  email            String        @unique
  passwordHash     String
  name             String
  active           Boolean       @default(true)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  roles            UserRole[]
  sessions         Session[]
  staffOf          StoreStaff[]
  addresses        Address[]
  cart             Cart?
  orders           Order[]
  pickTasks        PickTask[]    @relation("PickerTasks")
  driverDeliveries Delivery[]    @relation("DriverDeliveries")
  tipsReceived     Tip[]         @relation("DriverTips")
  deviceTokens     DeviceToken[]
  favorites        Favorite[]
  storeFollows     StoreFollow[]
  // Veículo da frota que o entregador selecionou para o turno corrente (story 15).
  // Opcional; relação fraca (SetNull) para não bloquear soft-delete de veículo.
  activeVehicle    Vehicle?      @relation("DriverActiveVehicle", fields: [activeVehicleId], references: [id], onDelete: SetNull)
  activeVehicleId  String?
  // Turno/disponibilidade do entregador (story 62). null = indisponível (de folga);
  // timestamp = disponível desde (exibível). Global ao driver — o turno é da pessoa,
  // não por loja. Logout desliga o turno.
  driverAvailableAt DateTime?

  @@map("users")
}

model Role {
  id    String     @id @default(cuid())
  name  RoleName   @unique
  users UserRole[]

  @@map("roles")
}

model UserRole {
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)
  roleId String

  @@id([userId, roleId])
  @@map("user_roles")
}

// Refresh-token session. Suporta rotação e revogação (detecção de reuse).
model Session {
  id                  String    @id @default(cuid())
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId              String
  refreshTokenHash    String
  userAgent           String?
  expiresAt           DateTime
  revokedAt           DateTime?
  replacedBySessionId String?
  createdAt           DateTime  @default(now())

  @@index([userId])
  @@map("sessions")
}

// Papel do funcionário dentro de uma loja.
enum StaffRole {
  admin // administrador da loja: acesso total à loja (inclui integração) e gere manager|picker|driver (story 16)
  manager // usuário do merchant que gerencia a loja
  picker // separador (faz o picking)
  driver // entregador da loja (entrega própria, SF-delivery)
}

// Tipo do veículo de entrega da frota da rede (story 14).
enum VehicleType {
  motorcycle // moto
  car // carro
  van // utilitário/van
}

// Veículo de entrega da frota da rede (story 14). Pertence ao MERCHANT (rede),
// não à loja: a frota é compartilhada entre as lojas; o entregador (que pertence a
// uma loja) escolhe entre os veículos da rede dona da loja (story 15). Desativação
// é soft (`active=false`) para preservar histórico de quem entregou com qual veículo.
model Vehicle {
  id          String      @id @default(cuid())
  merchant    Merchant    @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  merchantId  String
  plate       String // placa
  type        VehicleType
  description String? // texto livre, ex.: "Fiorino branca"
  active      Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  deliveries  Delivery[]
  // Entregadores que selecionaram este veículo como ativo no turno (story 15).
  activeDrivers User[]    @relation("DriverActiveVehicle")

  @@index([merchantId])
  @@map("vehicles")
}

// Vínculo de um usuário (funcionário) a uma loja específica, com papel operacional.
model StoreStaff {
  id        String    @id @default(cuid())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  store     Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  storeId   String
  staffRole StaffRole
  active    Boolean   @default(true)
  createdAt DateTime  @default(now())

  @@unique([userId, storeId, staffRole])
  @@index([storeId])
  @@map("store_staff")
}

// ─────────────────────────────────────────────────────────────
// Catálogo (S1.1)
// Produto CANÔNICO (global) é separado da OFERTA (por loja). Isso viabiliza
// dedup e enriquecimento entre lojas/merchants.
// ─────────────────────────────────────────────────────────────

enum EnrichmentStatus {
  pending
  enriched
  needs_review
}

// Como o produto é vendido — dirige o input de quantidade no carrinho.
// unit = embalado (conta unidades); weight = vendido por peso (carne, frutas, frios).
enum SaleType {
  unit
  weight
}

// Rede/varejista (ex.: Supermercado Europa).
model Merchant {
  id               String       @id @default(cuid())
  name             String
  slug             String       @unique
  // logo exibida no app cliente (upload via admin → S3/MinIO)
  logoUrl          String?
  active           Boolean      @default(true)
  // Integração ERP (S1.2): tipo de conector e config (ex.: { "dir": "..." } pro CSV).
  connectorType    String?
  connectorConfig  Json?
  // Tarifas (S2.4) — em centavos / basis points.
  deliveryFeeCents Int          @default(700)
  prepFeeCents     Int          @default(0)
  platformFeeBps   Int          @default(1000) // 1000 = 10%
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  stores           Store[]
  orderGroups      OrderGroup[]
  coupons          Coupon[]
  apiKeys          ApiKey[]
  webhooks         Webhook[]
  vehicles         Vehicle[]

  @@map("merchants")
}

// Api-key de ENTRADA (sistema do merchant → MarketHub) — story 09.
// Persistimos só o hash da chave; o valor em claro é revelado UMA vez na criação.
// `prefix` (primeiros caracteres) identifica a chave na listagem sem expor o valor.
model ApiKey {
  id         String    @id @default(cuid())
  merchant   Merchant  @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  merchantId String
  name       String
  keyHash    String // SHA-256 da chave em claro (nunca o valor)
  prefix     String // primeiros chars (ex.: "mk_live_a1b2") p/ identificação
  createdAt  DateTime  @default(now())
  lastUsedAt DateTime?
  revokedAt  DateTime?

  @@index([merchantId])
  @@map("api_keys")
}

// Webhook de SAÍDA (MarketHub → endpoint do merchant) — story 09.
// O secret assina o corpo (HMAC-SHA256, header X-MarketHub-Signature). Revelado
// uma vez na criação; depois retornado mascarado. Eventos cobertos no MVP:
// order.created e order.status_changed.
model Webhook {
  id                 String    @id @default(cuid())
  merchant           Merchant  @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  merchantId         String
  url                String
  secret             String // usado para assinar; mascarado nas leituras
  events             String[]
  active             Boolean   @default(true)
  lastDeliveryStatus String? // ok | failed | pending
  lastDeliveryAt     DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([merchantId])
  @@map("webhooks")
}

// Loja física de um merchant. Origem dos dados do ERP.
model Store {
  id            String         @id @default(cuid())
  merchant      Merchant       @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  merchantId    String
  name          String
  externalId    String? // id da loja no ERP do merchant
  // endereço
  street        String?
  number        String?
  district      String?
  city          String?
  state         String?
  zipCode       String?
  latitude      Float?
  longitude     Float?
  // contato exibido no resumo da loja (modal explore — story 29)
  phone         String?
  // permite retirada de pedidos na loja (badge "Retirar na loja" — story 29)
  allowsPickup  Boolean        @default(true)
  // tempo médio de preparo do pedido (min) — compõe o ETA real (S6.7)
  avgPrepMinutes Int           @default(15)
  // Config de entrega por loja (story 58). `null` = herda a tarifa da rede
  // (Merchant.deliveryFeeCents) / não tem pedido mínimo / sem raio além da cidade.
  deliveryFeeCents  Int?
  minOrderCents     Int?
  deliveryRadiusKm  Float?
  active        Boolean        @default(true)
  // Pausa temporária de emergência (story 57): null = operando; timestamp = "pausada
  // desde HH:MM". Independente de `active` (ativação administrativa) e do horário
  // semanal. Pausa bloqueia TODO pedido novo (imediato e agendado).
  pausedAt      DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  offers        Offer[]
  stocks        Stock[]
  staff         StoreStaff[]
  orderGroups   OrderGroup[]
  deliverySlots DeliverySlot[]
  hours         StoreHours[]
  closures      StoreClosure[]
  followers     StoreFollow[]

  @@unique([merchantId, externalId])
  @@index([merchantId])
  @@map("stores")
}

// Fechamento excepcional da loja num dia específico (feriado, evento — story 52).
// Fecha o dia INTEIRO (`date` @db.Date, sem hora), sobrepondo o horário semanal.
// `reason` é texto livre opcional (ex.: "Feriado"). Uma linha por (loja, data).
model StoreClosure {
  id        String   @id @default(cuid())
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  storeId   String
  date      DateTime @db.Date
  reason    String?
  createdAt DateTime @default(now())

  @@unique([storeId, date])
  @@index([storeId])
  @@map("store_closures")
}

// Horário de funcionamento da loja por dia da semana (story 29). Uma faixa
// abre–fecha por dia (`dayOfWeek` 0=domingo..6=sábado); `opensAt`/`closesAt` em
// minutos desde a meia-noite (ex.: 8h = 480) p/ comparação livre de timezone.
// Dia sem linha = fechado nesse dia. Janelas que cruzam a meia-noite ficam fora
// de escopo (assume `closesAt > opensAt`).
model StoreHours {
  id        String   @id @default(cuid())
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  storeId   String
  dayOfWeek Int // 0=domingo .. 6=sábado
  opensAt   Int // minutos desde a meia-noite
  closesAt  Int // minutos desde a meia-noite

  @@index([storeId])
  @@map("store_hours")
}

// Categoria CRUA (origem ERP/Cosmos, criada automaticamente). Mapeia para uma categoria
// CURADA (MarketplaceCategory) que é o que aparece no marketplace.
model Category {
  id                    String               @id @default(cuid())
  name                  String
  slug                  String               @unique
  parent                Category?            @relation("CategoryTree", fields: [parentId], references: [id])
  parentId              String?
  children              Category[]           @relation("CategoryTree")
  products              Product[]
  mappings              CategoryMapping[]
  // Curadoria: categoria do marketplace que agrupa esta categoria crua.
  marketplaceCategory   MarketplaceCategory? @relation(fields: [marketplaceCategoryId], references: [id])
  marketplaceCategoryId String?

  @@index([parentId])
  @@index([marketplaceCategoryId])
  @@map("categories")
}

// Categoria CURADA, gerida pelo admin — é o que aparece no marketplace (app cliente).
model MarketplaceCategory {
  id            String                @id @default(cuid())
  name          String
  slug          String                @unique
  displayOrder  Int                   @default(0)
  visible       Boolean               @default(true)
  // pergunta de preparo do departamento (S6.6): { label, options[] } — null = sem pergunta
  prepOptions   Json?
  parent        MarketplaceCategory?  @relation("MktCatTree", fields: [parentId], references: [id])
  parentId      String?
  children      MarketplaceCategory[] @relation("MktCatTree")
  rawCategories Category[]
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  @@index([parentId])
  @@index([visible, displayOrder])
  @@map("marketplace_categories")
}

// Produto canônico (global, cross-loja). Enriquecido pelo pipeline (S1.5).
model Product {
  id                String             @id @default(cuid())
  gtin              String?            @unique // EAN/GTIN normalizado quando houver
  name              String
  brand             String?
  packageSize       String? // rótulo descritivo da embalagem: "2L", "380g", "1kg"
  saleType          SaleType           @default(unit) // un|weight — dirige input de quantidade no carrinho
  imageUrl          String?
  description       String?
  category          Category?          @relation(fields: [categoryId], references: [id])
  categoryId        String?
  enrichmentStatus  EnrichmentStatus   @default(pending)
  completenessScore Int                @default(0) // 0-100
  // Origem do produto: erp | cosmos | merchant (cadastrado pelo manager — S3.10).
  source            String             @default("erp")
  createdById       String? // manager que cadastrou (produto local — S3.10)
  // Campos editados manualmente (S1.7) que o pipeline NÃO sobrescreve.
  lockedFields      String[]           @default([])
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  offers            Offer[]
  stocks            Stock[]
  enrichment        ProductEnrichment?

  @@index([name])
  @@index([brand])
  @@index([categoryId])
  @@index([enrichmentStatus])
  @@map("products")
}

// Oferta de um produto numa loja: preço + disponibilidade. Reconcilia ERP via externalId.
model Offer {
  id              String     @id @default(cuid())
  store           Store      @relation(fields: [storeId], references: [id], onDelete: Cascade)
  storeId         String
  product         Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId       String
  externalId      String? // id do produto no ERP daquela loja
  priceCents      Int
  promoPriceCents Int?
  available       Boolean    @default(true)
  // Campos editados manualmente pelo manager (S3.9) que o sync ERP NÃO sobrescreve.
  lockedFields    String[]   @default([])
  updatedById     String? // auditoria: último editor manual (User)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  cartItems       CartItem[]
  favorites       Favorite[]

  @@unique([storeId, productId])
  @@unique([storeId, externalId])
  @@index([productId])
  @@map("offers")
}

// Estoque por loja/produto (quantidade opcional; alguns ERPs só dão flag).
model Stock {
  id           String   @id @default(cuid())
  store        Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  storeId      String
  product      Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId    String
  quantity     Int?
  available    Boolean  @default(true)
  // Campos editados manualmente pelo manager (S3.9) que o sync ERP NÃO sobrescreve.
  lockedFields String[] @default([])
  updatedById  String? // auditoria: último editor manual (User)
  updatedAt    DateTime @updatedAt

  @@unique([storeId, productId])
  @@index([productId])
  @@map("stocks")
}

// ─────────────────────────────────────────────────────────────
// Integração ERP — auditoria de sync (S1.2)
// ─────────────────────────────────────────────────────────────

enum SyncType {
  full
  prices
  stock
}

enum SyncStatus {
  running
  success
  failed
}

model SyncRun {
  id             String     @id @default(cuid())
  storeId        String
  type           SyncType
  status         SyncStatus @default(running)
  startedAt      DateTime   @default(now())
  finishedAt     DateTime?
  itemsProcessed Int        @default(0)
  itemsUpdated   Int        @default(0)
  itemsFailed    Int        @default(0)
  error          String?

  @@index([storeId, startedAt])
  @@map("sync_runs")
}

// ─────────────────────────────────────────────────────────────
// Enriquecimento (S1.5) — Cosmos Bluesoft + mapeamento de categoria
// ─────────────────────────────────────────────────────────────

// Cache de respostas do Cosmos por GTIN (rate limit + evitar recomputo).
model CosmosCache {
  gtin      String   @id
  found     Boolean
  payload   Json?
  fetchedAt DateTime @default(now())

  @@map("cosmos_cache")
}

// Mapeamento categoria de origem (ex.: Cosmos GPC/descrição) → Category da plataforma.
// Persistido e reusado; IA/heurística só roda para sourceKey novo.
model CategoryMapping {
  id         String    @id @default(cuid())
  source     String // "cosmos"
  sourceKey  String // texto da categoria de origem
  category   Category? @relation(fields: [categoryId], references: [id])
  categoryId String?
  confidence Float     @default(0)
  mapper     String // "heuristic" | "ai" | "manual"
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@unique([source, sourceKey])
  @@map("category_mappings")
}

// Dados crus do enriquecimento + proveniência por campo (auditoria).
model ProductEnrichment {
  productId  String   @id
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  source     String // "cosmos" | "mock"
  raw        Json?
  provenance Json? // { name: "cosmos", category: "heuristic", ... }
  fetchedAt  DateTime @default(now())

  @@map("product_enrichments")
}

// ─────────────────────────────────────────────────────────────
// Marketplace — pedido, carrinho, endereço, cupom, pagamento (Fase 2)
// ─────────────────────────────────────────────────────────────

enum DeliveryMethod {
  gate // receber na portaria/portão
  door // entregar na porta (+taxa)
}

// Modalidade de cumprimento por loja (OrderGroup). Única operação do MVP:
// delivery = entrega feita pelo próprio mercado; pickup = cliente retira na loja.
enum FulfillmentType {
  delivery
  pickup
}

enum OrderStatus {
  created
  paid
  preparing
  picking
  ready_for_pickup // separado e empacotado, aguardando coleta do entregador (S3.1)
  on_the_way
  delivered
  canceled
}

enum PaymentStatus {
  pending
  paid
  expired
  failed
  refunded
}

enum CouponType {
  fixed // valor fixo em centavos
  percent // percentual (value = %)
  free_shipping
}

// Favorito de oferta (produto numa loja) do cliente (S6.5). Referência viva à Offer:
// preço/disponibilidade sempre atuais; se a Offer sumir, o app mostra indisponível.
model Favorite {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  offer     Offer    @relation(fields: [offerId], references: [id], onDelete: Cascade)
  offerId   String
  createdAt DateTime @default(now())

  @@unique([userId, offerId])
  @@index([userId])
  @@map("favorites")
}

// Loja seguida pelo cliente (story 34). Espelha Favorite, mas referencia a LOJA
// (não a oferta): casa com a rota /store/:id. Idempotente via @@unique.
model StoreFollow {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  storeId   String
  createdAt DateTime @default(now())

  @@unique([userId, storeId])
  @@index([userId])
  @@map("store_follows")
}

model Address {
  id         String   @id @default(cuid())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String
  label      String // Casa, Trabalho...
  street     String
  number     String
  district   String?
  city       String
  state      String
  zipCode    String
  complement String?
  latitude   Float?
  longitude  Float?
  isDefault  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  orders     Order[]

  @@index([userId])
  @@map("addresses")
}

model Cart {
  id         String     @id @default(cuid())
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String     @unique
  couponCode String?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  items      CartItem[]

  @@map("carts")
}

model CartItem {
  id          String   @id @default(cuid())
  cart        Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  cartId      String
  offer       Offer    @relation(fields: [offerId], references: [id], onDelete: Cascade)
  offerId     String
  quantity    Int      @default(1) // saleType=unit: nº de unidades
  weightGrams Int? // saleType=weight: gramas
  note        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([cartId, offerId])
  @@index([cartId])
  @@map("cart_items")
}

model Coupon {
  id            String     @id @default(cuid())
  code          String     @unique
  type          CouponType
  value         Int        @default(0) // fixed: centavos; percent: %
  merchant      Merchant?  @relation(fields: [merchantId], references: [id])
  merchantId    String? // null = global
  minOrderCents Int?
  validFrom     DateTime?
  validTo       DateTime?
  maxUses       Int?
  usedCount     Int        @default(0)
  active        Boolean    @default(true)
  createdAt     DateTime   @default(now())

  @@map("coupons")
}

model Order {
  id               String         @id @default(cuid())
  user             User           @relation(fields: [userId], references: [id])
  userId           String
  status           OrderStatus    @default(created)
  // entrega
  address          Address?       @relation(fields: [addressId], references: [id])
  addressId        String?
  deliveryMethod   DeliveryMethod @default(gate)
  scheduledFrom    DateTime?
  scheduledTo      DateTime?
  // slot de capacidade reservado no checkout (S5.3); libera ao cancelar
  deliverySlot     DeliverySlot?  @relation(fields: [deliverySlotId], references: [id])
  deliverySlotId   String?
  // snapshot do endereço (caso o Address mude/seja apagado)
  addressSnapshot  Json?
  // totais (centavos)
  itemsCents       Int            @default(0)
  deliveryCents    Int            @default(0)
  prepCents        Int            @default(0)
  platformFeeCents Int            @default(0)
  discountCents    Int            @default(0)
  totalCents       Int            @default(0)
  couponCode       String?
  // código de entrega (entregador→cliente): exibido ao cliente; o entregador digita p/ confirmar (SF.1)
  deliveryCode     String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  groups           OrderGroup[]
  payment          Payment?
  refund           Refund?
  reviews          Review[]
  tip              Tip?

  @@index([userId, createdAt])
  @@index([status])
  @@index([deliverySlotId])
  @@map("orders")
}

model OrderGroup {
  id               String            @id @default(cuid())
  order            Order             @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId          String
  merchant         Merchant          @relation(fields: [merchantId], references: [id])
  merchantId       String
  store            Store             @relation(fields: [storeId], references: [id])
  storeId          String
  status           OrderStatus       @default(created)
  // modalidade de cumprimento desta loja (entrega própria ou retirada)
  fulfillment      FulfillmentType   @default(delivery)
  subtotalCents    Int               @default(0)
  deliveryCents    Int               @default(0)
  prepCents        Int               @default(0)
  platformFeeCents Int               @default(0)
  // código de coleta (loja→entregador): exibido ao entregador; o picker/merchant digita p/ liberar (SF.1)
  pickupCode       String?
  // push ao ERP (S2.7)
  externalOrderId  String?
  erpPushedAt      DateTime?
  items            OrderItem[]
  pickTask         PickTask?
  refundComponents RefundComponent[]
  // entrega própria desta loja (só existe quando fulfillment = delivery)
  delivery         Delivery?

  @@index([orderId])
  @@index([storeId])
  @@map("order_groups")
}

model OrderItem {
  id             String     @id @default(cuid())
  group          OrderGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  groupId        String
  // snapshot (catálogo pode mudar depois)
  productId      String?
  offerId        String?
  nameSnapshot   String
  gtinSnapshot   String?
  saleType       SaleType   @default(unit)
  unitPriceCents Int // unit: preço/un; weight: preço/kg
  quantity       Int        @default(1)
  weightGrams    Int?
  lineTotalCents Int
  pickItem       PickItem?

  @@index([groupId])
  @@map("order_items")
}

model Payment {
  id               String        @id @default(cuid())
  order            Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId          String        @unique
  provider         String // "pagarme" | "mock"
  providerChargeId String?
  method           String        @default("pix")
  status           PaymentStatus @default(pending)
  amountCents      Int
  pixQrCode        String?
  pixQrCodeUrl     String?
  expiresAt        DateTime?
  paidAt           DateTime?
  raw              Json?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@index([providerChargeId])
  @@map("payments")
}

enum RefundStatus {
  pending // criado, ainda não processado no gateway
  processed // estorno confirmado pelo provider
  failed // gateway recusou o estorno
}

enum RefundReason {
  weight_shortfall // separou menos gramas que o pedido (item de peso)
  refused // item recusado/sem estoque (valor integral)
  group_canceled // sub-pedido (OrderGroup) cancelado pela loja/marketplace — total do grupo com cupom rateado (story 54)
  manual // reembolso manual do suporte (admin) — valor arbitrário até o teto (story 67)
}

// Reembolso único por Order (SF.3): consolida faltas de peso e itens recusados de
// todos os grupos. amountCents = max(0, pago − total ajustado). Breakdown por grupo
// em RefundComponent (contábil/repasse ao merchant).
model Refund {
  id               String            @id @default(cuid())
  order            Order             @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId          String            @unique
  amountCents      Int
  status           RefundStatus      @default(pending)
  provider         String // "pagarme" | "mock"
  providerRefundId String?
  reason           String // resumo legível (ex.: "weight_shortfall+refused")
  createdAt        DateTime          @default(now())
  processedAt      DateTime?
  components       RefundComponent[]

  @@map("refunds")
}

model RefundComponent {
  id           String       @id @default(cuid())
  refund       Refund       @relation(fields: [refundId], references: [id], onDelete: Cascade)
  refundId     String
  orderGroup   OrderGroup   @relation(fields: [orderGroupId], references: [id], onDelete: Cascade)
  orderGroupId String
  amountCents  Int
  reason       RefundReason
  // trilha mínima do reembolso manual (story 67): admin que criou (weak ref, sem FK)
  createdById  String?

  @@index([refundId])
  @@index([orderGroupId])
  @@map("refund_components")
}

// ─────────────────────────────────────────────────────────────
// Picking / Separação (Fase 3 — S3.1)
// Uma PickTask por OrderGroup (sub-pedido de uma loja). O separador (picker)
// resolve item a item, ensacola e libera p/ coleta do entregador via pickupCode.
// ─────────────────────────────────────────────────────────────

enum PickTaskStatus {
  queued // gerada, aguardando separador assumir
  assigned // separador assumiu
  picking // separação em andamento
  packed // itens ensacolados/prontos
  ready_for_pickup // pronta p/ coleta do entregador
}

enum PickItemStatus {
  pending // ainda não resolvido ("a selecionar")
  picked // separado ("selecionado")
  refused // sem estoque/avariado, removido ("reembolsado")
  substituted // substituído por outro produto
}

enum SubstitutionStatus {
  pending // aguardando aprovação do cliente
  approved
  rejected
}

model PickTask {
  id           String         @id @default(cuid())
  orderGroup   OrderGroup     @relation(fields: [orderGroupId], references: [id], onDelete: Cascade)
  orderGroupId String         @unique
  storeId      String // denormalizado p/ fila/índice por loja (== orderGroup.storeId)
  picker       User?          @relation("PickerTasks", fields: [pickerId], references: [id])
  pickerId     String?
  status       PickTaskStatus @default(queued)
  assignedAt   DateTime?
  startedAt    DateTime?
  packedAt     DateTime?
  readyAt      DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  items        PickItem[]

  @@index([storeId, status])
  @@index([pickerId])
  @@map("pick_tasks")
}

model PickItem {
  id                String         @id @default(cuid())
  pickTask          PickTask       @relation(fields: [pickTaskId], references: [id], onDelete: Cascade)
  pickTaskId        String
  orderItem         OrderItem      @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  orderItemId       String         @unique
  status            PickItemStatus @default(pending)
  quantityPicked    Int? // saleType=unit: unidades efetivamente separadas
  weightGramsPicked Int? // saleType=weight: gramas efetivamente separadas
  refusalReason     String? // motivo quando refused
  pickedById        String? // auditoria: quem resolveu
  pickedAt          DateTime?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  substitution      Substitution?

  @@index([pickTaskId])
  @@map("pick_items")
}

// Proposta de substituto para um item sem estoque. Snapshot de preço (não referência
// viva à Offer) p/ congelar o valor mostrado/aprovado pelo cliente.
model Substitution {
  id                  String             @id @default(cuid())
  pickItem            PickItem           @relation(fields: [pickItemId], references: [id], onDelete: Cascade)
  pickItemId          String             @unique
  substituteOfferId   String? // Offer proposta (referência fraca; sem FK p/ preservar histórico)
  substituteProductId String?
  nameSnapshot        String // nome do substituto no momento da proposta
  unitPriceCents      Int // preço do substituto no momento
  priceDiffCents      Int // substituto - original (pode ser negativo)
  approvalStatus      SubstitutionStatus @default(pending)
  resolvedAt          DateTime?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  @@map("substitutions")
}

// ─────────────────────────────────────────────────────────────
// Delivery / Entrega própria pela loja (MVP)
// Entrega feita pelo próprio mercado: 1 Delivery por OrderGroup (entrega),
// atribuída manualmente pela loja a um entregador vinculado (StoreStaff role driver).
// Coleta liberada por pickupCode (OrderGroup); entrega confirmada por deliveryCode (Order).
// ─────────────────────────────────────────────────────────────

enum DeliveryStatus {
  unassigned // pronta, aguardando a loja atribuir um entregador
  assigned // atribuída a um entregador, ainda não coletada
  picked_up // entregador coletou na loja (a caminho)
  delivered // entregue ao cliente
  failed // entregador não conseguiu entregar (cliente ausente, endereço errado…) — loja decide (story 61)
  canceled // cancelada
}

// Motivo da falha de entrega reportada pelo entregador (story 61).
enum DeliveryFailReason {
  customer_absent // cliente ausente
  wrong_address // endereço errado/não localizado
  refused // cliente recusou o pedido
  other // outro (detalhe em failNote)
}

// Entrega de uma OrderGroup feita por um entregador da própria loja.
model Delivery {
  id           String              @id @default(cuid())
  orderGroup   OrderGroup          @relation(fields: [orderGroupId], references: [id], onDelete: Cascade)
  orderGroupId String              @unique
  storeId      String // denormalizado p/ fila por loja
  driver       User?               @relation("DriverDeliveries", fields: [driverId], references: [id])
  driverId     String?
  // Veículo usado nesta entrega (story 14): histórico de qual veículo da frota fez a
  // entrega. Opcional; só é preenchido a partir da story 15 (seleção pelo entregador).
  vehicle      Vehicle?            @relation(fields: [vehicleId], references: [id])
  vehicleId    String?
  status       DeliveryStatus      @default(unassigned)
  assignedAt   DateTime?
  pickedUpAt   DateTime?
  deliveredAt  DateTime?
  // Falha na entrega (story 61): só a ÚLTIMA falha é guardada (histórico fora de escopo).
  // Preservados no retry (failed → unassigned) para a loja saber o que aconteceu.
  failReason   DeliveryFailReason?
  failNote     String?
  failedAt     DateTime?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  @@index([storeId, status])
  @@index([driverId, status])
  @@map("deliveries")
}

// ─────────────────────────────────────────────────────────────
// Avaliações multi-eixo e gorjeta (S5.2)
// Após delivered, o cliente avalia em eixos (plataforma/entrega/merchant) e pode
// dar gorjeta ao entregador (entrega própria → driverId vem da Delivery do grupo).
// ─────────────────────────────────────────────────────────────

enum ReviewAxis {
  platform // experiência da plataforma
  delivery // entrega/entregador (só quando houve entrega)
  merchant // a loja/merchant
}

enum TipStatus {
  pending // gorjeta criada, cobrança PIX pendente
  paid // confirmada via webhook
  failed // cobrança falhou/expirou
}

model Review {
  id               String     @id @default(cuid())
  order            Order      @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId          String
  axis             ReviewAxis
  rating           Int // 1..5
  comment          String?
  // alvos (weak ref, sem FK p/ preservar histórico) — usados nas agregações
  targetMerchantId String?
  targetDriverId   String?
  // resposta do lojista (story 56): 1 resposta por review, editável (update sobrescreve; sem histórico)
  replyText        String?
  repliedAt        DateTime?
  createdAt        DateTime   @default(now())

  // platform/delivery: 1 por pedido; merchant: 1 por mercado do pedido
  // (NULLs são distintos no Postgres; unicidade dos eixos sem alvo é garantida no service)
  @@unique([orderId, axis, targetMerchantId])
  @@index([targetMerchantId])
  @@index([targetDriverId])
  @@map("reviews")
}

model Tip {
  id               String    @id @default(cuid())
  order            Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId          String    @unique
  driver           User      @relation("DriverTips", fields: [driverId], references: [id])
  driverId         String
  amountCents      Int
  status           TipStatus @default(pending)
  provider         String // "pagarme" | "mock"
  providerChargeId String?
  pixQrCode        String?
  pixQrCodeUrl     String?
  expiresAt        DateTime?
  paidAt           DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([driverId, status])
  @@index([providerChargeId])
  @@map("tips")
}

// ─────────────────────────────────────────────────────────────
// Agendamento por capacidade / slots por loja (S5.3)
// Cada loja entrega o próprio pedido; a capacidade limita pedidos por janela.
// Aplica-se a entrega e retirada. Reserva decrementa ao criar, libera ao cancelar.
// ─────────────────────────────────────────────────────────────

model DeliverySlot {
  id        String   @id @default(cuid())
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  storeId   String
  start     DateTime
  end       DateTime
  capacity  Int      @default(0)
  reserved  Int      @default(0)
  createdAt DateTime @default(now())
  orders    Order[]

  @@unique([storeId, start, end])
  @@index([storeId, start])
  @@map("delivery_slots")
}

// ─────────────────────────────────────────────────────────────
// Notificações push (S5.6) — token de device por usuário
// ─────────────────────────────────────────────────────────────

enum DevicePlatform {
  ios
  android
  web
}

model DeviceToken {
  id         String         @id @default(cuid())
  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String
  platform   DevicePlatform
  token      String         @unique
  createdAt  DateTime       @default(now())
  lastSeenAt DateTime       @default(now())

  @@index([userId])
  @@map("device_tokens")
}

// ─────────────────────────────────────────────────────────────
// Eventos de domínio (story 45) — transactional outbox
// O agregado grava o evento NA MESMA TX da mudança de estado (OutboxPublisher);
// o relay (poll BullMQ) faz fan-out de 1 job por handler inscrito e marca
// publishedAt. Idempotência de handler em ProcessedEvent (eventId+handler).
// ─────────────────────────────────────────────────────────────

model OutboxEvent {
  id          String    @id @default(cuid())
  type        String // ex.: "order.paid"
  payload     Json
  aggregateId String // ex.: orderId — consulta/debug por agregado
  createdAt   DateTime  @default(now())
  publishedAt DateTime? // null = pendente de relay

  @@index([publishedAt])
  @@index([aggregateId])
  @@map("outbox_events")
}

// Dedupe de entrega at-least-once: 1 linha por (evento, handler) processado.
// eventId é fk LÓGICA p/ OutboxEvent.id (sem FK física — permite expurgo do outbox
// sem perder a trava). O PK composto é a unique de idempotência.
model ProcessedEvent {
  eventId     String
  handler     String
  processedAt DateTime @default(now())

  @@id([eventId, handler])
  @@map("processed_events")
}

// ─────────────────────────────────────────────────────────────
// Qualidade de catálogo (S5.5) — snapshot de cobertura ao longo do tempo
// ─────────────────────────────────────────────────────────────

model CatalogQualitySnapshot {
  id            String   @id @default(cuid())
  capturedAt    DateTime @default(now())
  totalProducts Int
  avgScore      Int // média do completenessScore (0-100)
  distribution  Json // histograma por faixa de score
  byStatus      Json // contagem por enrichmentStatus

  @@index([capturedAt])
  @@map("catalog_quality_snapshots")
}
